VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# URL pública do app (usada nas mensagens de WhatsApp). Se vazio, usa a origem atual.
# VITE_APP_URL=https://seu-dominio.com

# Só para scripts de import (NÃO use no frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PIX Sicredi — configurar como secrets da Edge Function `pix-sicredi`
# (npx supabase secrets set ... --project-ref ...)
# SICREDI_PIX_CLIENT_ID=
# SICREDI_PIX_CLIENT_SECRET=
# SICREDI_PIX_CHAVE=
# SICREDI_PIX_CERT=        # conteúdo .crt/.pem (use \n para quebras)
# SICREDI_PIX_KEY=         # conteúdo .key
# SICREDI_PIX_BASE_URL=https://api-pix.sicredi.com.br
# SICREDI_PIX_OAUTH_PATH=/oauth/token
# SICREDI_PIX_API_PATH=/api/v2

